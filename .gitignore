# Build artifacts
bin/
obj/
.vs/
packages/
*.user
*.suo
deploy/*.zip

# Runtime data (generated by execution - contains secrets)
Logs/

# Allow safe template files in Logs/ (no secrets)
!Logs/Dashboard.html
!Logs/localization.js
!Logs/ExtensionGroups.json
!Logs/DashboardConfig.json

# Sensitive files (secrets, certificates, API keys)
*.pfx
*.cer
*.key
appsettings.*.json
secrets.json

# SharePoint data files
SharePointSiteUsageStorage*.csv
*.csv.bak

# Internal / not for distribution
docs/
Examples/
.github/
_analysis_results.txt
_analyze.ps1

# OS
Thumbs.db
Desktop.ini
