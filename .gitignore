# Build artifacts
bin/
obj/
.vs/
packages/
*.user
*.suo
deploy/*.zip

# Runtime data (generated by execution)
Logs/

# Config directory - ignore contents (secrets in AppPaths.json) but track directory
config/*
!config/DashboardConfig.json
!config/ExtensionGroups.json

# Sensitive files (secrets, certificates, API keys)
*.pfx
*.cer
*.key
appsettings.*.json
secrets.json

# SharePoint data files
SharePointSiteUsageStorage*.csv
*.csv.bak

# Internal / not for distribution
docs/*
!docs/index.html
!docs/screenshots/
Examples/
# .github/ — tracked for CI workflows
_analysis_results.txt
_analyze.ps1

# OS
Thumbs.db
Desktop.ini
