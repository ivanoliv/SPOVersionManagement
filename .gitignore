# Build artifacts
bin/
obj/
.vs/
packages/
*.user
*.suo
deploy/*.zip

# App binaries (built by dotnet publish, too large for git)
app/

# Runtime data (generated by execution)
Logs/

# Config directory - ignore contents (secrets in AppPaths.json) but track directory
config/*
!config/AppPaths.json
!config/DashboardConfig.json
!config/ExtensionGroups.json
!config/version.json

# Sensitive files (secrets, certificates, API keys)
*.pfx
*.cer
*.key
appsettings.*.json
secrets.json

# SharePoint data files
SharePointSiteUsageStorage*.csv
*.csv.bak

# Internal / not for distribution
docs/*
!docs/index.html
!docs/_config.yml
!docs/_layouts/
!docs/_includes/
!docs/guides/
!docs/screenshots/
!docs/ww-savings.html
!docs/sitemap.xml
!docs/sitemap/
!docs/robots.txt
!docs/WINDOWS_APP.md
!docs/es/
!docs/pt/
!docs/de/
!docs/fr/
!docs/ja/
Examples/
# .github/ — tracked for CI workflows
_analysis_results.txt
_analyze.ps1

# OS
Thumbs.db
Desktop.ini
